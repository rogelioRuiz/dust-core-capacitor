{
  "name": "dust-core-capacitor",
  "version": "0.1.5",
  "description": "ML contract library for Capacitor — protocols, interfaces, and shared value types for on-device ML plugins.",
  "main": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "type": "module",
  "author": "Rogelio Ruiz Perez",
  "repository": {
    "type": "git",
    "url": "https://github.com/rogelioRuiz/dust-core-capacitor.git"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "files": [
    "dist/esm/",
    "android/src/main/",
    "android/build.gradle",
    "ios/Sources/",
    "DustCoreCapacitor.podspec",
    "Package.swift"
  ],
  "keywords": [
    "capacitor",
    "plugin",
    "ml",
    "inference",
    "protocol",
    "contract",
    "ai"
  ],
  "license": "Apache-2.0",
  "peerDependencies": {
    "@capacitor/core": "^7.0.0 || ^8.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@capacitor/core": "^8.0.0",
    "typescript": "~5.7.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
